# cube.obj

mtllib mtl.mtl

# Vertices

# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #
# Vertex Positions: (x, y, z)
# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #
# Front Top Left            Magenta
v -0.5  0.5  0.5            1.0 0.0 1.0

# Front Top Right           Magenta
v  0.5  0.5  0.5            1.0 0.0 1.0

# Front Bottom Left         Magenta
v -0.5 -0.5  0.5            1.0 0.0 1.0

# Front Bottom Right        Magenta
v  0.5 -0.5  0.5            1.0 0.0 1.0

# Back Top Left             Cyan
v -0.5  0.5 -0.5            0.0 1.0 1.0

# Back Top Right            Cyan
v  0.5  0.5 -0.5            0.0 1.0 1.0

# Back Bottom Left          Cyan
v -0.5 -0.5 -0.5            0.0 1.0 1.0

# Back Bottom Right         Cyan
v  0.5 -0.5 -0.5            0.0 1.0 1.0
# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #

# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #
# Tex Coords: (u, v)
# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #
# Top left
vt 0.0 0.0

# Top Right
vt 1.0 0.0

# Bottom Left
vt 0.0 1.0

# Bottom Right
vt 1.0 1.0
# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #

# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #
# Vertex Normals: Unit direction vectors (x, y, z)
# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #
# X+
vn 1.0 0.0 0.0

# X-
vn -1.0 0.0 0.0

# Y+
vn 0.0 1.0 0.0

# Y-
vn 0.0 -1.0 0.0

# Z+
vn 0.0 0.0 1.0

# Z-
vn 0.0 0.0 -1.0
# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #



# Faces: One vertex = v/vt/vn

# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #
# Front face (+Z)
usemtl Red
f 1/1/5 3/3/5 2/2/5
f 2/2/5 3/3/5 4/4/5

# Back face (-Z)
usemtl Green
f 6/1/6 8/3/6 5/2/6
f 5/2/6 8/3/6 7/4/6

# Top face (+Y)
usemtl Blue
f 5/1/3 1/3/3 6/2/3
f 6/2/3 1/3/3 2/4/3

# Bottom face (-Y)
usemtl Yellow
f 3/1/4 7/3/4 4/2/4
f 4/2/4 7/3/4 8/4/4

# Left face (-X)
usemtl Cyan
f 5/1/2 7/3/2 1/2/2
f 1/2/2 7/3/2 3/4/2

# Right face (+X)
usemtl Magenta
f 2/1/1 4/3/1 6/2/1
f 6/2/1 4/3/1 8/4/1
# ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #